# ============================================================
# Gluten 构建配置文件
# 所有外部依赖和版本在此集中定义，便于维护和升级
# ============================================================

# -------------------- 构建工具路径 --------------------
# JDK 8
JAVA_HOME=/opt/buildtools/openjdk8/jdk8u462-b08
JRE_HOME=/opt/buildtools/openjdk8/jdk8u462-b08/jre

# Maven
MAVEN_HOME=/opt/buildtools/apache-maven/apache-maven-3.9.9

# LLVM
LLVM_HOME=/opt/buildtools/LLVM-15.0.4

# CMake
CMAKE_HOME=/opt/buildtools/cmake-3.28.2-linux-aarch64

# Protobuf
PROTOBUF_HOME=/opt/buildtools/Protobuf-3.21.9

# -------------------- 系统库路径 --------------------
FMT_HOME=/usr/local
FOLLY_HOME=/usr/local

# -------------------- 版本配置 --------------------
# OmniOperator 版本
OMNI_OPERATOR_VERSION=2.1.0

# Arrow 版本
ARROW_VERSION=15.0.0

# libboundscheck 版本
LIBBOUNDSCHECK_VERSION=v1.1.16

# Spark 版本映射 (根据 gluten_branch 自动选择)
# 2026_330_poc -> 3.5, 其他 -> 3.4

# -------------------- OS 配置 --------------------
OS_TYPE=openeuler-sve

# -------------------- 产物版本 --------------------
PRODUCT_VERSION=2.0.0
COMPONENT_VERSION=2.0.0

# -------------------- 代码仓库地址 --------------------
# 格式: REPO_<名称>_URL 和 REPO_<名称>_DIR
REPO_GLUTEN_URL=https://gitcode.com/openeuler/Gluten.git
REPO_GLUTEN_DIR=gluten

REPO_OMNIOPERATOR_URL=https://gitcode.com/openeuler/OmniOperator.git
REPO_OMNIOPERATOR_DIR=OmniOperatorJIT

REPO_LIBBOUNDSCHECK_URL=https://gitcode.com/openeuler/libboundscheck.git
REPO_LIBBOUNDSCHECK_DIR=libboundscheck

# -------------------- 预编译依赖包下载地址 --------------------
# 华为云 OBS 基础地址
OBS_BASE_URL=https://boostkit-bigdata-public.obs.cn-north-4.myhuaweicloud.com/artifact

# OmniOperator 运行时包 (根据分支选择不同路径)
OMNI_OPERATOR_PACKAGE_PATH_2026_330_POC=OmniOperator/2026_330_poc/Daily.26.0.0.B001
OMNI_OPERATOR_PACKAGE_PATH_MASTER=OmniOperator/master/Daily.26.0.0.B001

# Native Reader JAR
NATIVE_reader_PACKAGE_PATH=omniop_native_reader/br_feature_omnioperator_spark_2026_330/Daily.26.0.0.B001

# Arrow 预编译包
ARROW_PACKAGE_PATH=Gluten/Compile_Rely

# -------------------- 系统依赖库路径 --------------------
DEPENDENCIES_GlUTEN_PATH=/opt/Dependencies_openEuler22.03_Gluten
DEPENDENCIES_ADAPTOR_PATH=/opt/Dependencies_openEuler22.03_Adaptor

# -------------------- Maven 依赖坐标 --------------------
# Native Reader
NATIVE_reader_GROUP_ID=com.huawei.boostkit
NATIVE_reader_ARTIFACT_ID=boostkit-omniop-native-reader
NATIVE_reader_VERSION=3.4.3-${OMNI_OPERATOR_VERSION}

# OmniOperator UDF
OMNI_UDF_GROUP_ID=com.huawei.boostkit
OMNI_UDF_ARTIFACT_ID=boostkit-omniop-udf
OMNI_UDF_CLASSIFIER=aarch64

# OmniOperator Bindings
OMNI_BINDINGS_GROUP_ID=com.huawei.boostkit
OMNI_BINDINGS_ARTIFACT_ID=boostkit-omniop-bindings
OMNI_BINDINGS_CLASSIFIER=aarch64

# -------------------- Maven 构建参数 --------------------
MAVEN_PROFILE_OMNI=-Pbackends-omni
MAVEN_PROFILE_ICEBERG=-Piceberg
MAVEN_SKIP_TESTS=-DskipTests
MAVEN_SKIP_CHECKS=-Dspotless.check.skip=true -Dscalastyle.skip=true -Dcheckstyle.skip=true